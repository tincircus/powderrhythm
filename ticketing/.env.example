# Copy to .env for local development. Railway injects these automatically — do not commit .env

PORT=3000

# Leave unset in development to use SQLite (dev.sqlite)
# Set to your Railway Postgres URL in production
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Railway private network URL — only available inside Railway containers.
# Takes priority over DATABASE_URL; uses ssl:false (Wireguard encrypts private network).
# Never set this locally — Railway DNS is not resolvable outside Railway.
# DATABASE_PRIVATE_URL=postgresql://user:password@postgres.railway.internal:5432/railway

# Admin and scanner shared password (Phase 2+)
# ADMIN_PASSWORD=changeme

# --- Phase 2: Square Integration ---

# Square API credentials (Sandbox for dev, Production for deploy)
# Obtain from: Square Developer Dashboard → Applications → your app → Credentials
SQUARE_ACCESS_TOKEN=sandbox-sq0idb-REPLACE_ME

# Square location ID — from Square Developer Dashboard → Locations
SQUARE_LOCATION_ID=REPLACE_ME

# Webhook signature key — from Square Developer Dashboard → Webhooks → your subscription
SQUARE_WEBHOOK_SIGNATURE_KEY=REPLACE_ME

# Exact URL where the webhook is registered in Square dashboard (must match byte-for-byte)
# Dev: use ngrok tunnel URL (e.g., https://abc123.ngrok.io/webhooks/square)
# Prod: https://tickets.powderrhythm.com/webhooks/square
SQUARE_WEBHOOK_URL=https://REPLACE_ME/webhooks/square

# Base URL of this app — used to build the Square payment link redirect URL
# Dev: http://localhost:3000  |  Prod: https://tickets.powderrhythm.com
APP_URL=http://localhost:3000
