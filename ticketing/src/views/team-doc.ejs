<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — Powder Rhythm Team</title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Boogaloo&family=Fredoka+One&family=Permanent+Marker&family=Special+Elite&display=swap" rel="stylesheet" />
  <style>
    :root {
        --deep-purple: #1a0033;
        --neon-teal:   #00ffcc;
        --neon-pink:   #ff00cc;
        --snow-white:  #f0f8ff;
    }
    *, *::before, *::after { box-sizing: border-box; }
    body {
        background-color: var(--deep-purple);
        background-image:
            radial-gradient(ellipse at 20% 50%, rgba(0,255,204,0.08) 0%, transparent 60%),
            radial-gradient(ellipse at 80% 20%, rgba(255,0,204,0.08) 0%, transparent 60%);
        color: var(--snow-white);
        font-family: 'Special Elite', cursive;
        margin: 0;
        padding: 0 16px;
        min-height: 100vh;
    }
    .page-container { max-width: 820px; margin: 0 auto; padding: 32px 0 64px; }
    .topnav { margin-bottom: 24px; }
    .topnav a {
        font-family: 'Boogaloo', cursive;
        color: var(--neon-teal);
        text-decoration: none;
        font-size: 1.1rem;
    }
    .topnav a:hover { text-shadow: 0 0 12px rgba(0,255,204,0.6); }
    .content {
        background: rgba(255,255,255,0.04);
        border: 2px solid var(--neon-teal);
        border-radius: 12px;
        padding: 24px 32px;
    }
    .content h1 { font-family: 'Permanent Marker', cursive; font-size: 2.2rem; color: var(--neon-teal); margin: 8px 0 16px; }
    .content h2 { font-family: 'Fredoka One', cursive; font-size: 1.5rem; color: var(--neon-pink); margin: 28px 0 12px; }
    .content h3 { font-family: 'Fredoka One', cursive; font-size: 1.15rem; color: var(--neon-teal); margin: 22px 0 10px; }
    .content p, .content li { font-size: 1rem; line-height: 1.6; }
    .content a { color: var(--neon-teal); }
    .content code {
        background: rgba(0,255,204,0.12);
        padding: 1px 6px;
        border-radius: 4px;
        font-family: monospace;
        font-size: 0.9em;
    }
    .content table { border-collapse: collapse; width: 100%; margin: 16px 0; }
    .content th, .content td { border: 1px solid rgba(0,255,204,0.3); padding: 8px 12px; text-align: left; }
    .content th { background: rgba(0,255,204,0.08); font-family: 'Boogaloo', cursive; }
    .content blockquote { border-left: 3px solid var(--neon-pink); margin: 16px 0; padding: 4px 16px; color: rgba(240,248,255,0.8); }
    .content hr { border: none; border-top: 1px solid rgba(0,255,204,0.25); margin: 28px 0; }
    .content input[type="checkbox"] { margin-right: 8px; accent-color: var(--neon-teal); }
    .content ul li { list-style: none; }
    .content ul { padding-left: 8px; }
    .otherdocs { margin-top: 32px; font-family: 'Boogaloo', cursive; color: rgba(240,248,255,0.6); }
    .otherdocs a { color: var(--neon-teal); text-decoration: none; margin-right: 16px; }
  </style>
</head>
<body>
  <div class="page-container">
    <div class="topnav"><a href="/team">&larr; All team docs</a></div>
    <div class="content">
      <%- html %>
    </div>
    <div class="otherdocs">
      <% docs.filter(function (d) { return d.slug !== slug; }).forEach(function (d) { %>
        <a href="/team/<%= d.slug %>"><%= d.title %></a>
      <% }); %>
    </div>
  </div>
</body>
</html>
